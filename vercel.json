{
  "version": 2,
  "name": "seo-parasite-pro",
  "functions": {
    "api/register.js": {
      "maxDuration": 120,
      "memory": 1024
    },
    "api/universal-register.js": {
      "maxDuration": 120,
      "memory": 1024
    },
    "api/click-link.js": {
      "maxDuration": 60,
      "memory": 1024
    },
    "api/gb-post.js": {
      "maxDuration": 300,
      "memory": 1024
    },
    "api/captcha.js": {
      "maxDuration": 180,
      "memory": 512
    },
    "api/index.js": {
      "maxDuration": 60,
      "memory": 256
    },
    "api/proxy.js": {
      "maxDuration": 60,
      "memory": 256
    },
    "api/health.js": {
      "maxDuration": 30,
      "memory": 256
    },
    "api/headers.js": {
      "maxDuration": 30,
      "memory": 256
    },
    "api/whois.js": {
      "maxDuration": 30,
      "memory": 256
    },
    "api/ping.js": {
      "maxDuration": 30,
      "memory": 256
    },
    "api/supabase.js": {
      "maxDuration": 30,
      "memory": 256
    },
    "api/social-blast.js": {
      "maxDuration": 60,
      "memory": 512
    },
    "api/social-blast-queue.js": {
      "maxDuration": 60,
      "memory": 256
    },
    "api/social-blast-accounts.js": {
      "maxDuration": 120,
      "memory": 512
    }
  },
  "routes": [
    {
      "src": "/api/proxy-test",
      "dest": "/api/proxy?_mode=proxytest"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET,POST,OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type,X-API-Key,Authorization"
        }
      ]
    }
  ]
}
