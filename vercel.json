{
  "version": 2,
  "name": "seo-parasite-pro",
  "functions": {
    "api/register.mjs":           { "maxDuration": 120, "memory": 1024 },
    "api/universal-register.mjs": { "maxDuration": 120, "memory": 1024 },
    "api/click-link.mjs":         { "maxDuration": 60,  "memory": 1024 },
    "api/captcha.mjs":            { "maxDuration": 180, "memory": 512  },
    "api/index.mjs":              { "maxDuration": 60,  "memory": 256  },
    "api/proxy.mjs":              { "maxDuration": 30,  "memory": 256  },
    "api/health.mjs":             { "maxDuration": 30,  "memory": 256  },
    "api/headers.mjs":            { "maxDuration": 30,  "memory": 256  },
    "api/whois.mjs":              { "maxDuration": 30,  "memory": 256  },
    "api/ping.mjs":               { "maxDuration": 30,  "memory": 256  },
    "api/supabase.mjs":           { "maxDuration": 30,  "memory": 256  }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/",         "dest": "/index.html" },
    { "src": "/(.*)",     "dest": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin",  "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type,X-API-Key,Authorization" }
      ]
    }
  ]
}
